      },
      "choices": [{ "id": "l", "label": "前往实验室", "next": "lab" }]
    },
    "barracks": {
      "narrative": "宿舍空无一人，床铺整齐如从未使用。镜子上用 lipstick 写着：「别相信平的墙。」 所有镜子都映出比房间多一个角的空间。",
      "effects": { "location": "队员宿舍", "mapRoom": "barracks", "san": 2 },
      "choices": [
        { "id": "mirror", "label": "研究镜中异常", "next": "mirror_check", "skillCheck": { "skill": "神秘学" } },
        { "id": "back", "label": "返回枢纽", "next": "hub" }
      ]
    },
    "mirror_check": {
      "narrative": "镜中多出的角是样本的「锚点」。",
      "branch": { "success": "mirror_ok", "failure": "lab" }
    },
    "mirror_ok": {
      "narrative": "你理解：样本通过镜面折叠进入墙体。破坏镜子可暂时阻断扩散——但实验室是主巢。",
      "effects": { "journal": "镜为锚点；实验室是主巢。" },
      "choices": [{ "id": "lab3", "label": "前往实验室", "next": "lab" }]
    },
    "lab": {
      "narrative": "实验室B级隔离门被从内部熔穿。室内培养槽空无一物——但四面墙在缓慢「呼吸」，表面浮现非欧几何纹。中央悬浮着一块冰芯，内部有 moving shadow。",
      "effects": { "location": "生物实验室", "mapRoom": "lab", "san": 3, "atmosphere": { "level": "dread", "note": "几何样本" } },
      "choices": [
        { "id": "spec", "label": "进入标本冷库", "next": "specimen" },
        { "id": "destroy", "label": "尝试销毁冰芯", "next": "destroy_check", "skillCheck": { "skill": "科学" } }
      ]
    },
    "specimen": {
      "narrative": "冷库中堆满解剖过的队员——他们的内脏排列成 perfect fractal。墙上用 frozen blood 写着样本的「真名」——一串无法发音的几何符号。",
      "effects": { "location": "标本冷库", "mapRoom": "specimen", "san": 4 },
      "choices": [
        { "id": "name", "label": "记录真名并返回实验室", "next": "finale", "skillCheck": { "skill": "图书馆使用" } },
        { "id": "flee", "label": "逃向停机坪", "next": "ending_flee" }
      ]
    },
    "destroy_check": {
      "narrative": "冰芯对热与盐敏感。",
      "branch": { "success": "finale", "failure": "ending_taken" }
    },
    "finale": {
      "narrative": "你携带真名与盐回到实验室。墙体的呼吸加速——样本感知到威胁。",
      "branch": { "success": "ending_win", "failure": "ending_taken" }
    },
    "ending_win": {
      "narrative": "盐与真名共振，冰芯碎裂。墙体停止呼吸，折叠空间展平。陈博士被救出，长夜站永久封禁。南极的风里仍偶尔闪过几何 shadow。\n\n【结局：样本遏制】",
      "effects": { "journal": "摧毁样本，长夜站封锁。" },
      "end": true
    },
    "ending_taken": {
      "narrative": "墙体合拢。你成为样本的三维投影之一——在墙里与其他队员一同排列成 fractal。救援队只找到空无一人的实验室，墙上有新的人形轮廓。\n\n【结局：成为样本】",
      "effects": { "san": 8 },
      "end": true
    },
    "ending_flee": {
      "narrative": "你乘最后一班运输机逃离。回望时长夜站整栋建筑向内折叠，像被吸入一个点。官方报告：科考站因雪崩掩埋。\n\n【结局：逃离·真相被埋】",
      "end": true
    }
  }
