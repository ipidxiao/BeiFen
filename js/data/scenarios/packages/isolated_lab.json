    "arrival": {
      "narrative": "运输机离去。停机坪上积雪被染成暗红——不是血，是某种 phosphorescent 藻类。中央枢纽的门自动滑开，内部灯光闪烁，广播循环播放：「请保持隔离——样本已逃逸。」",
      "choices": [
        { "id": "hub", "label": "进入中央枢纽", "next": "hub" },
        { "id": "survivor", "label": "寻找幸存者", "next": "survivor_check", "skillCheck": { "skill": "侦查" } }
      ]
    },
    "survivor_check": {
      "narrative": "你在雪堆后发现蜷缩的人影。",
      "branch": { "success": "survivor_ok", "failure": "hub" }
    },
    "survivor_ok": {
      "narrative": "幸存者是地质学家陈博士。他语无伦次：「样本不是细菌——是几何。它在墙里生长。别进实验室。」",
      "effects": {
        "clues": [{ "id": "il_chen", "title": "陈博士证词", "content": "样本是几何生命体，在墙内生长。", "type": "testimony" }],
        "journal": "样本逃逸，与墙内几何体有关。"
      },
      "choices": [
        { "id": "h", "label": "进入枢纽", "next": "hub" },
        { "id": "lab", "label": "调查实验室", "next": "lab" }
      ]
    },
    "hub": {
      "narrative": "枢纽大厅墙上贴满隔离规程。一台终端仍运行，最后日志：「样本突破B级隔离——建议全员撤离——撤离失败。」 走廊通向实验室与宿舍。",
      "effects": { "location": "中央枢纽", "mapRoom": "hub" },
      "choices": [
        { "id": "lab2", "label": "前往生物实验室", "next": "lab" },
        { "id": "bar", "label": "搜查队员宿舍", "next": "barracks" },
        { "id": "term", "label": "导出终端数据", "next": "term_check", "skillCheck": { "skill": "计算机使用" } }
      ]
    },
    "term_check": {
      "narrative": "终端密码仍有效。",
      "branch": { "success": "term_ok", "failure": "hub" }
    },
    "term_ok": {
      "narrative": "数据揭示：样本来自冰芯深处，非地球生物。其结构在二维投影时呈现「墙」的形态——进入三维空间会折叠成封闭曲面。",
      "effects": {
        "clues": [{ "id": "il_data", "title": "冰芯样本数据", "content": "非地球几何生命；二维投影为墙。", "type": "document" }],
