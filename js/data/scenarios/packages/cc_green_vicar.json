  "description": "1925年萨默塞特郡，古老乡村教堂由戴木面具的村民侍奉「绿衣教士」。当地神父失踪，你的汽车神秘抛锚于村外。改编自 Krycek RPGs CC-BY 4.0 模组《Faces of the Green Man》。",
  "era": "1920s",
  "estimatedMinutes": 30,
  "startNode": "roadside",
  "initialLocation": "黑木村·村道",
  "setup": {
    "location": "黑木村·村道",
    "atmosphere": { "level": "calm", "note": "英格兰秋雾" },
    "map": {
      "title": "黑木村",
      "rooms": [
        { "id": "roadside", "name": "村道", "connections": ["village", "churchyard"] },
        { "id": "village", "name": "村广场", "connections": ["roadside", "inn", "churchyard"] },
        { "id": "inn", "name": "老橡树旅店", "connections": ["village"] },
        { "id": "churchyard", "name": "教堂墓地", "connections": ["roadside", "village", "church"] },
        { "id": "church", "name": "圣塞巴斯蒂安教堂", "connections": ["churchyard", "crypt"] },
        { "id": "crypt", "name": "地下 crypt", "connections": ["church"] }
      ],
      "currentRoomId": "roadside"
    },
    "journal": "调查黑木村失踪神父，并查明「绿衣教士」传闻。"
  },
  "nodes": {
    "roadside": {
      "narrative": "你的汽车停在村道中央，引擎毫无征兆地熄火。雾从两侧 hedgerow 渗出，远处教堂尖顶在灰白天空下像一根骨刺。路边立着一块木牌，上面用绿漆画着一张人脸——五官由藤蔓与橡叶组成。",
      "choices": [
        { "id": "village", "label": "步行进入村庄", "next": "village" },
        { "id": "engine", "label": "检查引擎", "next": "engine_check", "skillCheck": { "skill": "机械维修" } }
      ]
    },
    "engine_check": {
      "narrative": "打开引擎盖……",
      "branch": { "success": "engine_ok", "failure": "village" }
    },
    "engine_ok": {
      "narrative": "点火线圈被整齐剪断——切口新鲜，像有人在你抵达前数分钟动手。引擎盖内侧用绿漆写着：「勿入绿林。」",
      "effects": {
        "clues": [{ "id": "cgv_coil", "title": "剪断的线圈", "content": "人为破坏；绿漆警告勿入绿林。", "type": "physical" }]
      },
      "choices": [{ "id": "walk", "label": "步行进村", "next": "village" }]
    },
    "village": {
      "narrative": "村广场空无一人，但每家门前都挂着同样的木面具——五官由藤蔓与橡叶组成。井台旁的黑板上写着今日布道词：「绿衣教士将引我们回家。」字迹湿润，像刚写不久。",
      "effects": { "location": "村广场", "mapRoom": "village" },
      "choices": [
        { "id": "inn", "label": "进入老橡树旅店", "next": "inn" },
        { "id": "churchyard", "label": "前往教堂墓地", "next": "churchyard" },
        { "id": "listen", "label": "倾听村民动静", "next": "listen_check", "skillCheck": { "skill": "聆听" } }
      ]
    },
    "listen_check": {
      "narrative": "雾中传来低语……",
      "branch": { "success": "listen_ok", "failure": "inn" }
    },
    "listen_ok": {
      "narrative": "你听见整齐的脚步声从教堂方向传来——节奏一致，像木偶被同一根线牵引。低语重复同一句话：「绿衣教士需要一张新脸。」",
      "effects": {
        "clues": [{ "id": "cgv_chant", "title": "村民低语", "content": "绿衣教士需要一张新脸。", "type": "witness" }],
        "san": 1
      },
      "choices": [{ "id": "cy", "label": "前往教堂", "next": "churchyard" }]
    },
    "inn": {
      "narrative": "旅店大门虚掩，柜台后无人。登记簿最后一页只有一行字：「所有房客已赴礼拜。」壁炉上方挂着神父照片——被人用绿漆涂掉了面部。",
      "effects": {
        "location": "老橡树旅店",
        "mapRoom": "inn",
        "clues": [{ "id": "cgv_photo", "title": "被涂改的神父照片", "content": "面部被绿漆覆盖。", "type": "physical" }]
      },
      "choices": [
        { "id": "register", "label": "翻阅登记簿", "next": "register" },
        { "id": "back", "label": "返回广场", "next": "village" }
      ]
    },
    "register": {
      "narrative": "登记簿记录：三天前最后一位外来者是「Thomas Hale，萨默塞特教区巡查员」——此后再无新条目。最后一页夹着一张便条，字迹颤抖：「他们不再摘下面具。绿衣教士住在 crypt 里。」",
      "effects": {
        "clues": [{ "id": "cgv_note", "title": "Hale 便条", "content": "村民不再摘面具；绿衣教士在 crypt。", "type": "document" }],
        "journal": "巡查员 Hale 可能仍在村中。"
      },
      "choices": [{ "id": "cy2", "label": "前往教堂", "next": "churchyard" }]
    },
    "churchyard": {
      "narrative": "墓地墓碑排列整齐，但每座坟前都放着一枚新鲜橡果。教堂门半开，内部传来齐声诵唱——声音不像来自喉咙，更像风穿过空心木。",
      "effects": { "location": "教堂墓地", "mapRoom": "churchyard", "san": 1 },
      "choices": [
        { "id": "church", "label": "进入教堂", "next": "church" },
        { "id": "graves", "label": "检查最新坟墓", "next": "graves_check", "skillCheck": { "skill": "侦查" } }
      ]
    },
    "graves_check": {
      "narrative": "最新坟墓的土被翻动……",
      "branch": { "success": "graves_ok", "failure": "church" }
    },
    "graves_ok": {
      "narrative": "最新坟墓属于失踪神父 Edmund Crane。棺盖未钉牢，内侧有从内向外抓挠的痕迹。棺中无遗体，只有一具戴木面具的稻草人。",
      "effects": {
        "clues": [{ "id": "cgv_grave", "title": "空棺", "content": "神父坟墓被从内打开；棺内为稻草人。", "type": "physical" }]
      },
      "choices": [{ "id": "ch", "label": "进入教堂", "next": "church" }]
    },
    "church": {
      "narrative": "教堂内，戴木面具的村民背对你跪在圣坛前。圣坛上不是十字架，而是一棵用绿漆涂成的小橡树。一名村民缓缓转头——面具下的脸是空白树皮。",
      "effects": { "location": "圣塞巴斯蒂安教堂", "mapRoom": "church", "san": 2, "atmosphere": { "level": "dread", "note": "木面低语" } },
      "choices": [
        { "id": "approach", "label": "接近圣坛", "next": "approach_check", "skillCheck": { "skill": "潜行" } },
        { "id": "call", "label": "大声询问神父下落", "next": "call_fail" },
        { "id": "crypt", "label": "寻找 crypt 入口", "next": "crypt_door_check", "skillCheck": { "skill": "图书馆使用" } }
      ]
    },
    "call_fail": {
      "narrative": "所有村民同时站起，齐声转向你。诵唱停止，只剩面具下空洞的风声：「绿衣教士需要一张新脸。」",
      "effects": { "san": 2 },
      "choices": [
        { "id": "run", "label": "冲向 crypt 侧门", "next": "crypt" },
        { "id": "fight", "label": "强行突围", "next": "fight_check", "skillCheck": { "skill": "斗殴" } }
      ]
    },
    "approach_check": {
      "narrative": "你沿侧廊潜行……",
      "branch": { "success": "approach_ok", "failure": "call_fail" }
    },
    "approach_ok": {
      "narrative": "圣坛后方发现被绑在橡木柱上的巡查员 Hale——他面部被剥去，露出底下正在发芽的嫩绿树皮。他嘶哑地说：「绿衣教士……在 crypt……需要你的脸……完成仪式……」",
      "effects": {
        "clues": [{ "id": "cgv_hale", "title": "巡查员 Hale", "content": "面部被替换为树皮；指向 crypt 仪式。", "type": "witness" }],
        "journal": "绿衣教士在 crypt 进行换脸仪式。"
      },
      "choices": [{ "id": "cr", "label": "进入 crypt", "next": "crypt" }]
    },
    "crypt_door_check": {
      "narrative": "你在圣坛地板找到活板门……",
      "branch": { "success": "crypt", "failure": "call_fail" }
    },
    "fight_check": {
      "narrative": "你与村民搏斗……",
      "branch": { "success": "crypt", "failure": "ending_captured" }
    },
    "crypt": {
      "narrative": "crypt 潮湿阴冷，根须从石壁钻出。中央立着一棵小型橡树，树干上嵌着多张人脸——其中一张是神父 Crane 的。树根缠绕着一具穿绿袍的躯体，头部是一顶由藤蔓编织的冠冕。",
      "effects": { "location": "地下 crypt", "mapRoom": "crypt", "san": 3, "atmosphere": { "level": "terror", "note": "绿衣教士" } },
      "choices": [
        { "id": "burn", "label": "用提灯点燃根须", "next": "burn_check", "skillCheck": { "skill": "敏捷" } },
        { "id": "face", "label": "取下神父的人脸", "next": "face_ritual" },
        { "id": "flee2", "label": "逃离 crypt", "next": "ending_flee" }
      ]
    },
    "burn_check": {
      "narrative": "火焰舔舐根须……",
      "branch": { "success": "ending_win", "failure": "ending_wounded" }
    },
    "face_ritual": {
      "narrative": "你触碰神父人脸的瞬间，根须缠上你的手腕。绿衣教士睁开没有瞳孔的眼睛：「一张新脸……终于来了。」",
      "effects": { "san": 5 },
      "choices": [
        { "id": "cut", "label": "砍断根须", "next": "burn_check", "skillCheck": { "skill": "力量" } },
        { "id": "submit", "label": "放弃抵抗", "next": "ending_captured" }
      ]
    },
    "ending_win": {
      "narrative": "火焰沿根须蔓延，绿衣教士发出风啸般的尖叫。Oak 冠冕碎裂，村民面具纷纷落地——底下是空无一物的脸。雾散去，你的汽车奇迹般能发动了。黑木村再无人应答，但 crypt 入口已被封死。\n\n【结局：仪式终止】",
      "effects": { "journal": "焚毁绿衣教士，黑木村化为空壳。" },
      "end": true
    },
    "ending_wounded": {
      "narrative": "火焰只烧到一半便熄灭。你带伤逃出，身后 crypt 传来新面孔加入树干的闷响。数周后，萨默塞特教区报告：黑木村所有村民「迁往他处」。\n\n【结局：生还·根须蔓延】",
      "effects": { "san": 4 },
      "end": true
    },
    "ending_captured": {
      "narrative": "根须缠住你的四肢，绿衣教士将树皮贴在你脸上。意识消散前，你听见自己的声音加入诵唱：「绿衣教士需要一张新脸。」\n\n【结局：成为新面具】",
      "effects": { "san": 10 },
      "end": true
    },
    "ending_flee": {
      "narrative": "你冲出 crypt，身后村庄在雾中消失。汽车能发动了，但后视镜里，你的倒影戴着木面具。\n\n【结局：逃离·面具跟随】",
      "effects": { "san": 5 },
      "end": true
    }
  }
}
