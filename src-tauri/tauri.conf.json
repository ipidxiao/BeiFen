{
  "build": {
    "devPath": "http://localhost:8080",
    "distDir": ".",
    "beforeDevCommand": "python3 -m http.server 8080",
    "beforeBuildCommand": ""
  },
  "package": {
    "productName": "CoC 7th Engine",
    "version": "16.5.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": true },
      "dialog": { "open": true, "save": true },
      "fs": { "scope": ["$APPDATA/**", "$DOCUMENT/**"] }
    },
    "bundle": {
      "active": true,
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
      "targets": ["msi", "nsis"]
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://cdn.jsdelivr.net; font-src 'self' data:; connect-src https://api.deepseek.com; frame-ancestors 'none'"
    },
    "windows": [
      {
        "title": "CoC 7th Engine — 克苏鲁的呼唤",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
